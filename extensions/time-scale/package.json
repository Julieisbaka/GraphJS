    "extension",
    "time",
    "scale",
    "plugin"
  ],
  "license": "MIT",
  "peerDependencies": {
    "graphjs": ">=0.2.8"
  },
  "scripts": {
    "lint": "node --check index.js",
    "build": "esbuild index.js --bundle --format=esm --outfile=dist/index.js && esbuild index.js --bundle --format=esm --minify --outfile=dist/index.min.js"
  }
